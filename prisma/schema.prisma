generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model MockAPI {
  id        String   @id @default(uuid())
  userId    String
  name      String
  endpoint  String
  method    String
  response  Json
  status    Int      @default(200)
  delay     Int?     @default(0)
  createdAt DateTime @default(now())
}
